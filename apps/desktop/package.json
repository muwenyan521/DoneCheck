{
  "name": "@donecheck/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "DoneCheck Desktop app",
  "homepage": "https://github.com/wangxianming/DoneCheck#readme",
  "author": {
    "name": "DoneCheck Contributors",
    "email": "maintainers@example.invalid"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup --config tsup.config.ts && vite build --config vite.config.ts",
    "lint": "biome check .",
    "test": "vitest run --testTimeout=10000",
    "test:mocked-smoke": "vitest run --testTimeout=10000 src/electron-smoke.test.ts",
    "typecheck": "tsc --noEmit",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "electron:smoke": "electron --no-sandbox dist/smoke.cjs",
    "electron:start": "electron --no-sandbox dist/electron.cjs",
    "rebuild:node": "pnpm rebuild better-sqlite3",
    "dist:dir": "electron-builder --dir",
    "dist:linux": "electron-builder --linux --x64",
    "dist:win": "electron-builder --win --x64",
    "package:dir": "node scripts/package-with-abi-restore.mjs dir",
    "package:linux": "node scripts/package-with-abi-restore.mjs linux",
    "package:win": "node scripts/package-with-abi-restore.mjs win",
    "smoke:packaged": "node scripts/smoke-packaged.mjs"
  },
  "dependencies": {
    "@donecheck/core": "workspace:*",
    "@donecheck/provider-openai": "workspace:*",
    "@donecheck/report-ui": "workspace:*",
    "@donecheck/shared": "workspace:*",
    "@donecheck/templates": "workspace:*",
    "better-sqlite3": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@donecheck/config": "workspace:*",
    "@electron/asar": "catalog:",
    "@electron/rebuild": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "electron": "catalog:",
    "electron-builder": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "^5.4.21",
    "vitest": "catalog:"
  }
}
